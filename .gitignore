# Environment variables (never commit real tokens)
.env

# SQLite database files
*.db
*.db-shm
*.db-wal

# Python cache
__pycache__/
*.py[cod]
*.pyo

# Node modules and accidentally-committed npm artifacts
node_modules/
buffer-alloc-unsafe/
package-lock.json

# Runtime state files
frog_states.json
frog_species_200.json

# IDE
.idea/
.vscode/

# pytest cache
.pytest_cache/
